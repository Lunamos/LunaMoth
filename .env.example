# NOTE: The LLM backend is normally configured in the welcome screen / Settings
# (the web deck or the TUI), which persists to ~/.lunamoth/config.json. That file
# WINS over the env vars below. These env vars only seed the very first launch
# when no config file exists yet — handy for headless/CI use.

# Default: offline mock narrative engine.
LLM_PROVIDER=mock

# OpenRouter (OpenAI-compatible) example:
# LLM_PROVIDER=openrouter
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=sk-or-...
# OPENAI_MODEL=meta-llama/llama-3.3-70b-instruct

# Ollama / OpenAI-compatible local endpoint example:
# LLM_PROVIDER=openai_compatible
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# OPENAI_MODEL=qwen2.5:3b-instruct
# LLM_TEMPERATURE=0.85
# Output-token cap. 0 = follow the model's reported limit (default 8192); >0 = explicit cap.
# LLM_MAX_TOKENS=0

# Isolation for the `terminal` tool: sandbox | admin.
#   sandbox = OS jail (sandbox-exec on macOS / bubblewrap or Landlock on Linux) — the default;
#             refuses to run if no jail is available rather than degrading.
#   admin   = no jail, your privileges (Claude-Code-style directory trust; opt-in, trusted operator).
# Normally set per session by `lunamoth new --isolation`; legacy values dir/local/docker map to admin.
LUNAMOTH_PY_BACKEND=sandbox

# Character card (normally chosen in the welcome screen / web deck). A card is the
# ONE content file: identity, voice, and the embedded world (character_book) all
# travel inside a single .json or .png (V2/V3). Empty => the bundled default card.
# LUNAMOTH_CHARACTER=cards/Quinn/card.json
# LUNAMOTH_USER=操作者
# To also scan an external SillyTavern data dir for cards, opt in explicitly:
# LUNAMOTH_ST_DIR=~/SillyTavern/data/default-user
