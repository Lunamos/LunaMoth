# NOTE: The LLM backend is normally configured in the TUI welcome screen
# (Ctrl+S to reopen), which persists to .lunamoth/config.json. That file WINS
# over the env vars below. These env vars only seed the very first launch when
# no config file exists yet — handy for headless/CI use.

# Default: offline mock narrative engine.
LLM_PROVIDER=mock

# OpenRouter (OpenAI-compatible) example:
# LLM_PROVIDER=openrouter
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=sk-or-...
# OPENAI_MODEL=meta-llama/llama-3.3-70b-instruct

# Ollama / OpenAI-compatible local endpoint example:
# LLM_PROVIDER=openai_compatible
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# OPENAI_MODEL=qwen2.5:3b-instruct
# LLM_TEMPERATURE=0.85
# LLM_MAX_TOKENS=420

# Eternal thinking / visible idle cycles
ETERNAL_THINKING=true
THOUGHT_INTERVAL_SECONDS=8
MAX_VISIBLE_MESSAGES=80
MAX_SESSION_THOUGHTS=32
THOUGHT_USE_LLM=true

# Isolation for the `terminal` tool: dir | sandbox | docker.
#   dir     = no jail, your privileges (Claude-Code-style directory trust)
#   sandbox = OS jail (sandbox-exec on macOS / bubblewrap on Linux) — the default
#   docker  = container (strongest). Normally set per session by `lunamoth new --isolation`.
LUNAMOTH_PY_BACKEND=sandbox

# SillyTavern-compatible persona (normally chosen in the welcome screen).
# Empty LUNAMOTH_CHARACTER => default character LunaMoth 月蛾 (characters/LunaMoth.<lang>.json),
# with its paired world book auto-loaded when LUNAMOTH_WORLD is also empty.
# Accepts a .png (V2/V3 card) or .json card; world book is a SillyTavern world .json.
# Language switching = pick the matching card/world (e.g. .zh vs .en).
# LUNAMOTH_CHARACTER=characters/SCP-079.zh.json
# LUNAMOTH_WORLD=worlds/SCP-Foundation.zh.json
# LUNAMOTH_USER=操作者
# Discovery scans ONLY the project characters/ and worlds/ by default (no external links).
# To also scan an external SillyTavern data dir, opt in explicitly:
# LUNAMOTH_ST_DIR=~/SillyTavern/data/default-user
